# Server Configuration
VITE_SERVER_PORT=53331

# Billing Configuration
# Set to false to disable billing features
VITE_BILLING_ENABLED=true

# Room Configuration (for multi-room setup)
# Format: JSON array of {name, ip, port}
# Example: [{"name":"Room 1","ip":"192.168.1.10","port":53331},{"name":"Room 2","ip":"192.168.1.11","port":53331}]
VITE_ROOMS=[{"name":"Room 1","ip":"192.168.1.10","port":53331}]
